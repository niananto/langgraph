# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# --- HuggingFace (required for real LLaMA 3.1 tokenization) ---
# Accept Meta's license at huggingface.co/meta-llama/Meta-Llama-3.1-8B
# then generate a Read token at huggingface.co/settings/tokens
HF_TOKEN=hf_...

# --- LLM provider (optional — falls back to local Ollama if unset) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama (optional — only needed if Ollama runs on a non-default host) ---
# OLLAMA_HOST=http://localhost:11434
