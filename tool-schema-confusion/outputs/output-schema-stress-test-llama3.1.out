[SCHEMA]
{
  "type": "function",
  "function": {
    "name": "place_order",
    "description": "Place a product order with shipping and payment details.",
    "parameters": {
      "properties": {
        "product_id": {
          "description": "Unique identifier of the product.",
          "type": "string"
        },
        "quantity": {
          "description": "Number of units to order.",
          "type": "integer"
        },
        "shipping": {
          "properties": {
            "address": {
              "properties": {
                "street": {
                  "description": "Street address including house/apt number.",
                  "type": "string"
                },
                "city": {
                  "description": "City name.",
                  "type": "string"
                },
                "country": {
                  "description": "Country name.",
                  "type": "string"
                },
                "zip_code": {
                  "description": "Postal / ZIP code.",
                  "type": "string"
                }
              },
              "required": [
                "street",
                "city",
                "country",
                "zip_code"
              ],
              "type": "object",
              "description": "Delivery address."
            },
            "method": {
              "description": "Shipping method: standard or express.",
              "type": "string"
            },
            "leave_at_door": {
              "description": "Whether to leave the parcel at the door.",
              "type": "boolean"
            }
          },
          "required": [
            "address",
            "method",
            "leave_at_door"
          ],
          "type": "object",
          "description": "Shipping address and delivery preferences."
        },
        "payment": {
          "properties": {
            "method": {
              "description": "Payment method: card or paypal.",
              "type": "string"
            },
            "card": {
              "properties": {
                "number": {
                  "description": "16-digit card number.",
                  "type": "string"
                },
                "expiry": {
                  "description": "Card expiry in MM/YY format.",
                  "type": "string"
                },
                "cvv": {
                  "description": "3 or 4 digit security code.",
                  "type": "string"
                }
              },
              "required": [
                "number",
                "expiry",
                "cvv"
              ],
              "type": "object",
              "description": "Card details (required when method is card)."
            }
          },
          "required": [
            "method",
            "card"
          ],
          "type": "object",
          "description": "Payment method and card details."
        }
      },
      "required": [
        "product_id",
        "quantity",
        "shipping",
        "payment"
      ],
      "type": "object"
    }
  }
}

