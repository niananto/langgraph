======================================================================
DEGREE 1  —  tool: book_restaurant
======================================================================

[SCHEMA]
{
  "type": "function",
  "function": {
    "name": "book_restaurant",
    "description": "Book a table at a restaurant.",
    "parameters": {
      "properties": {
        "restaurant_name": {
          "description": "Name of the restaurant.",
          "type": "string"
        },
        "date": {
          "description": "Reservation date in YYYY-MM-DD format.",
          "type": "string"
        },
        "time": {
          "description": "Reservation time in HH:MM (24h) format.",
          "type": "string"
        },
        "party_size": {
          "description": "Number of guests.",
          "type": "integer"
        },
        "outdoor_seating": {
          "description": "Whether outdoor seating is preferred.",
          "type": "boolean"
        }
      },
      "required": [
        "restaurant_name",
        "date",
        "time",
        "party_size",
        "outdoor_seating"
      ],
      "type": "object"
    }
  }
}

----------------------------------------------------------------------
[RAW]    content = ''
[PARSED] tool_calls =
           name='book_restaurant'
           args={
           "date": "2026-07-15",
           "time": "19:30",
