    "name": "deploy_application",
    "description": "Deploy a containerised application to a cloud cluster.",
    "parameters": {
      "properties": {
        "app_name": {
          "description": "Name of the application to deploy.",
          "type": "string"
        },
        "image_tag": {
          "description": "Docker image tag to deploy, e.g. v1.2.3.",
          "type": "string"
        },
        "cluster": {
          "properties": {
            "name": {
              "description": "Cluster name.",
              "type": "string"
            },
            "region": {
              "description": "Cloud region, e.g. us-central1.",
              "type": "string"
            },
            "node_pool": {
              "properties": {
                "size": {
                  "description": "Initial number of nodes.",
                  "type": "integer"
                },
                "machine_type": {
                  "description": "VM machine type, e.g. n2-standard-4.",
                  "type": "string"
                },
                "autoscaling": {
                  "properties": {
                    "enabled": {
                      "description": "Whether autoscaling is active.",
                      "type": "boolean"
                    },
                    "min_nodes": {
                      "description": "Minimum number of nodes.",
                      "type": "integer"
                    },
                    "max_nodes": {
                      "description": "Maximum number of nodes.",
                      "type": "integer"
                    },
                    "policy": {
                      "properties": {
                        "metric": {
                          "description": "Scaling metric: cpu_utilization or memory_utilization.",
                          "type": "string"
                        },
                        "target_threshold_pct": {
                          "description": "Target utilisation percentage to trigger scaling.",
                          "type": "integer"
                        },
