======================================================================
DEGREE 2  —  tool: plan_vacation
======================================================================

[SCHEMA]
{
  "type": "function",
  "function": {
    "name": "plan_vacation",
    "description": "Plan a vacation itinerary.",
    "parameters": {
      "properties": {
        "destination": {
          "description": "City or country to travel to.",
          "type": "string"
        },
        "duration_days": {
          "description": "Length of the trip in days.",
          "type": "integer"
        },
        "traveler": {
          "properties": {
            "name": {
              "description": "Full name of the traveller.",
              "type": "string"
            },
            "age": {
              "description": "Age in years.",
              "type": "integer"
            },
            "passport_number": {
              "description": "Passport number.",
              "type": "string"
            }
          },
          "required": [
            "name",
            "age",
            "passport_number"
          ],
          "type": "object",
          "description": "Information about the traveller."
        },
        "budget": {
          "properties": {
            "amount": {
              "description": "Numerical budget value.",
              "type": "integer"
            },
            "currency": {
              "description": "ISO 4217 currency code, e.g. USD.",
              "type": "string"
            }
          },
          "required": [
            "amount",
            "currency"
          ],
          "type": "object",
          "description": "Total travel budget."
        },
        "preferences": {
          "properties": {
            "accommodation_type": {
              "description": "E.g. hotel, hostel, airbnb.",
              "type": "string"
            },
            "activity_focus": {
              "description": "E.g. adventure, culture, relaxation.",
              "type": "string"
            }
          },
          "required": [
            "accommodation_type",
            "activity_focus"
          ],
          "type": "object",
          "description": "Accommodation and activity preferences."
        }
      },
      "required": [
        "destination",
        "duration_days",
        "traveler",
        "budget",
        "preferences"
      ],
      "type": "object"
    }
  }
}

